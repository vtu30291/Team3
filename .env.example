# Flask Server Settings
FLASK_PORT=5000

# Database Settings (MySQL)
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=rag_db

# Ollama REST API Configuration
OLLAMA_BASE_URL=http://localhost:11434

# Internal Server Storage Path
# Will dynamically generate subdirectories /pdfs and /vector_store inside this path
STORAGE_DIR=./storage
